{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WinTweak AI",
  "version": "0.1.0",
  "identifier": "ai.wintweak.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "capabilities": ["main"]
    },
    "windows": [
      {
        "label": "main",
        "title": "WinTweak AI",
        "width": 1180,
        "height": 760,
        "minWidth": 840,
        "minHeight": 560,
        "resizable": true,
        "devtools": false,
        "browserExtensionsEnabled": false,
        "windowEffects": {
          "effects": ["mica"]
        }
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"]
  }
}
